# Copy to .env (never commit .env). Use Railway public DATABASE_URL for local dev.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# Clerk — required together if CLERK_SECRET_KEY is set (see packages/api/src/server.ts).
# If you only set the secret key, clerkMiddleware will run and /health may error without the publishable key.
CLERK_SECRET_KEY=""
CLERK_PUBLISHABLE_KEY=""

# Set to true only for local development without Clerk (sends `x-demo-user-id` header).
ALLOW_DEMO_AUTH="false"
