# demo (default): no Clerk key required; data from @hourly/shared + local Zustand store.
# live: set EXPO_PUBLIC_DATA_MODE=live and provide Clerk + API URL.
EXPO_PUBLIC_DATA_MODE=demo

EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
EXPO_PUBLIC_API_URL=http://localhost:3001/trpc
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=PLACEHOLDER_GOOGLE_MAPS_API_KEY
EXPO_PUBLIC_DEMO_USER_ID=user-001

# Used for portfolio share links and certificate copy (e.g. https://your-vercel-app.vercel.app).
EXPO_PUBLIC_WEB_BASE_URL=http://localhost:3002
