{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:mobile-web",
  "outputDirectory": "apps/mobile/dist",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/((?!.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
